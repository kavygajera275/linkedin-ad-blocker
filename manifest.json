{
  "manifest_version": 3,
  "name": "LinkedIn Ad Blocker",
  "version": "3.0",
  "description": "LinkedIn Ad Blocker with Counter",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"]
    }
  ]
}